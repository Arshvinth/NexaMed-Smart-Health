PORT=5001
NODE_ENV=development

# Per-service MongoDB connection overrides (for microservices)
USER_MONGODB_URI=mongodb://mongo:27017/user_service
DOCTOR_MONGODB_URI=mongodb://mongo:27017/doctor_service
APPOINTMENT_MONGODB_URI=mongodb://mongo:27017/appointment_service
PAYMENT_MONGODB_URI=mongodb://mongo:27017/payment_service
PATIENT_MONGODB_URI=mongodb://mongo:27017/patient_service

### Quick switch: single cloud DB for all services
# If want all services to use a single cloud MongoDB (single DB or same URI),
# GLOBAL_MONGODB_URI=mongodb+srv://...

# Behavior:
# - If `GLOBAL_MONGODB_URI` is set, every service's `MONGODB_URI` will use it.
# - Otherwise each service uses its per-service env var if present, or falls back to the local `mongo` container default.

# JWT configuration
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=7d
CORS_ORIGIN=http://localhost:3000

# Admin seeding configuration
ADMIN_SEED_ENABLED=true
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@nexamed.com
ADMIN_PASSWORD=Admin@123

INTERNAL_API_SECRET=0c154...

# Stripe configuration
STRIPE_SECRET_KEY=sk_test_51TI6...
STRIPE_PUBLISHABLE_KEY=pk_test_5...
STRIPE_WEBHOOK_SECRET=whse...