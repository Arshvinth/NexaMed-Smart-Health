# Telemedicine service port
PORT=5005

# Environment (development|test|production)
NODE_ENV=development

# Allow your frontend origin
CORS_ORIGIN=http://localhost:3000

# Dev auth mode (matches doctor-service approach before JWT)
# dev: reads x-user-id and x-role headers
# jwt: (future) validate real JWT tokens
AUTH_MODE=jwt
JWT_SECRET=change_me_super_secret