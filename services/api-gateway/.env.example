### API Gateway environment configuration (example)

# Port for the API gateway HTTP server
# Default in code: 5000
PORT=5000

# Upstream service URLs

# Doctor service (prescriptions, doctor profiles, availability)
DOCTOR_SERVICE_URL=http://localhost:5002

# Appointment service (booking, doctor/patient appointments)
APPOINTMENT_SERVICE_URL=http://localhost:5003

# Telemedicine service (video sessions)
TELEMEDICINE_SERVICE_URL=http://localhost:5005

#Patient service (Medical Report,Prescription,patient profiles)
PATIENT_SERVICE_URL=http://localhost:5006

# CORS configuration
# Frontend origin allowed to call the gateway
CORS_ORIGIN=http://localhost:3000

# Node environment
NODE_ENV=development

